{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "balance": { "type": "number", "description": "Current balance in IDR" },
        "hasClaimedBonus": { "type": "boolean", "description": "Whether the user has claimed the initial 200k bonus" },
        "totalDeposited": { "type": "number", "description": "Total amount deposited, used to check withdrawal eligibility" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "hasClaimedBonus", "totalDeposited", "createdAt"]
    },
    "Trade": {
      "title": "Trade",
      "description": "A trading position",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "amount": { "type": "number", "description": "Amount invested" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "profit": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "entryPrice", "status", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit or withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/trades/{tradeId}": {
      "schema": { "$ref": "#/entities/Trade" },
      "description": "User trades"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User deposits and withdrawals"
    }
  }
}